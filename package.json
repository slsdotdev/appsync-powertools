    "url": "https://github.com/slsdotdev/gqlbase/issues"
  },
  "homepage": "https://github.com/slsdotdev/gqlbase#readme",
  "packageManager": "^npm@10.9.6",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.9.6",
    "yarn": "use-npm",
    "pnpm": "use-npm"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-turbo": "^2.9.4",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "turbo": "^2.9.4",
    "typescript": "^6.0.2",
